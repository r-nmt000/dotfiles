// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-0": "agent::ToggleFocus",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-?": "agent::ToggleFocus",
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-0": "agent::ToggleFocus"
    }
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "cmd-0": "workspace::CloseActiveDock"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-7": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-`": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-2": "outline_panel::ToggleFocus"
    }
  },
  {
    "context": "Pane",
    "unbind": {
      "cmd-7": "outline_panel::ToggleFocus"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-2": "outline_panel::ToggleFocus"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-shift-b": "outline_panel::ToggleFocus"
    }
  },
  {
    "context": "OutlinePanel",
    "bindings": {
      "cmd-2": "workspace::CloseActiveDock"
    }
  },
  {
    "context": "OutlinePanel",
    "unbind": {
      "cmd-7": "workspace::CloseActiveDock"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-9": "git_panel::ToggleFocus"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-k": "git_panel::ToggleFocus"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-9": "git_panel::ToggleFocus"
    }
  },
  {
    "context": "Pane",
    "unbind": {
      "cmd-0": "git_panel::ToggleFocus"
    }
  },
  {
    "context": "GitPanel",
    "bindings": {
      "cmd-9": "workspace::CloseActiveDock"
    }
  },
  {
    "context": "GitPanel",
    "unbind": {
      "cmd-0": "workspace::CloseActiveDock"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-7": "workspace::CloseActiveDock"
    }
  },
  {
    "context": "Terminal",
    "unbind": {
      "alt-f12": "workspace::CloseActiveDock"
    }
  },
  {
    "bindings": {
      "cmd-7": "terminal_panel::ToggleFocus"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-g h": "git::FileHistory"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-g d": "git::Diff"
    }
  },
  {
    "context": "AcpThread > Editor",
    "unbind": {
      "ctrl-shift-d": "git::Diff"
    }
  },
  {
    "context": "ThreadsSidebar",
    "bindings": {
      "ctrl-h": "agents_sidebar::ToggleThreadHistory",
      "ctrl-s": [
        "agents_sidebar::ToggleThreadSwitcher",
        {
          "select_last": true
        }
      ]
    }
  },
  {
    "unbind": {
      "cmd-0": "git_panel::ToggleFocus"
    }
  },
  {
    "unbind": {
      "cmd-0": [
        "zed::ResetBufferFontSize",
        {
          "persist": false
        }
      ]
    }
  },

  // ===== Migrated from .ideavimrc =====

  // Insert mode: C-j to escape (JIS keyboard friendly)
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl-j": "vim::NormalBefore"
    }
  },

  // Normal mode: word ops, line jumps, soft-line motion, x without yank
  {
    "context": "Editor && VimControl && !VimWaiting && !menu",
    "bindings": {
      "v x": ["workspace::SendKeystrokes", "v a w x h"],
      "y w": ["workspace::SendKeystrokes", "y i w"],
      "d w": ["workspace::SendKeystrokes", "d i w"],
      "c w": ["workspace::SendKeystrokes", "c i w"],
      "0": "vim::FirstNonWhitespace",
      "]": "vim::EndOfLine",
      "j": "vim::Down",
      "k": "vim::Up",
      "x": ["workspace::SendKeystrokes", "\" _ x"],
      "enter": ["workspace::SendKeystrokes", "i enter escape"]
    }
  },

  // Visual mode: keep selection on indent, x without yank, vv to end of line
  {
    "context": "vim_mode == visual",
    "bindings": {
      ">": ["workspace::SendKeystrokes", "> g v"],
      "<": ["workspace::SendKeystrokes", "< g v"],
      "x": ["workspace::SendKeystrokes", "\" _ x"],
      "v": ["workspace::SendKeystrokes", "$ h"]
    }
  },

  // Window splits & navigation (s prefix, IdeaVim style)
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "s s": "pane::SplitDown",
      "s v": "pane::SplitRight",
      "s x": "pane::CloseActiveItem",
      "s h": "workspace::ActivatePaneLeft",
      "s j": "workspace::ActivatePaneDown",
      "s k": "workspace::ActivatePaneUp",
      "s l": "workspace::ActivatePaneRight",

      // Tab (Zed では Pane Item) operations
      "t n": "pane::AlternateFile",
      "t x": "pane::CloseActiveItem",
      "t l": "pane::ActivateNextItem",
      "t h": "pane::ActivatePreviousItem"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "alt-cmd-j": "multi_workspace::ToggleWorkspaceSidebar"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-8": [
        "workspace::ActivatePane",
        7
      ]
    }
  },
  {
    "context": "Pane",
    "unbind": {
      "cmd-8": null
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-8": "multi_workspace::FocusWorkspaceSidebar"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "alt-cmd-;": "multi_workspace::FocusWorkspaceSidebar"
    }
  }
]
