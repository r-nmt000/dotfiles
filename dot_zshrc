#Customize to your needs...

HISTFILE=$HOME/.zsh-history           # 履歴をファイルに保存する
HISTSIZE=100000                       # メモリ内の履歴の数
SAVEHIST=100000                       # 保存される履歴の数
setopt extended_history               # 履歴ファイルに時刻を記録
setopt hist_ignore_dups               # 重複するリストを無視
setopt share_history                  # 履歴を共有
setopt nonomatch                      # glob失敗時の警告をやめさせる
function history-all { history -E 1 } # 全履歴の一覧を出力する
#C-pとC-nを履歴検索に割り当て
autoload history-search-end
zle -N history-beginning-search-backward-end history-search-end
zle -N history-beginning-search-forward-end history-search-end
bindkey "^[[A" history-beginning-search-backward-end
bindkey "^[[B" history-beginning-search-forward-end
#zshの補完機能（antidote の oh-my-zsh lib が compdef を必要とするため、antidote load より前に呼ぶ）
autoload -U compinit
compinit

# Load plugins via antidote
if [ -f $HOME/.zsh/.zshrc.antidote ]; then
   source ~/.zsh/.zshrc.antidote
fi



#zshの言語設定
export LANG=ja_JP.UTF-8
#cd入力しないでcd
setopt auto_cd
#cdの履歴保存
setopt auto_pushd
#同じディレクトリは追加しない
setopt pushd_ignore_dups
# cdしたあとに自動ls
function chpwd() { ls }

# zshでautojumpを使えるようにする
if [[ -s /opt/homebrew/etc/autojump.sh ]]; then
  source /opt/homebrew/etc/autojump.sh
fi

#リストをつめて表示
setopt list_packed
#BGの処理が終了したら即時報告
setopt notify

#Term2のタブ名を変更する
DISABLE_AUTO_TITLE="true"
function title {
  echo -ne "\033]0;"$*"\007"
  # echo -ne "\033]0;${USER}@${HOSTNAME}: ${PWD}\007"
}

########################
#       alias          #
########################

# tree
alias tree="tree -NC" # N: 文字化け対策, C:色をつける

# tmuxで日本語を使えるように
alias tmux="tmux -u"

########################
# settings for each OS #
########################

case ${OSTYPE} in
  darwin*)
    #Settings for Mac
    source ~/.zsh/.zshrc.darwin
    ;;
esac


# Read settings for local user
# Write down some specific settings in .zsh_prifile
if [ -f $HOME/.zsh_profile ]; then
   source ~/.zsh_profile
fi

# Read work specific settings
if [ -f $HOME/.zshrc.work ]; then
   source ~/.zshrc.work
fi

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

# Starship prompt (must be at the end of .zshrc)
if command -v starship >/dev/null 2>&1; then
    eval "$(starship init zsh)"
fi
