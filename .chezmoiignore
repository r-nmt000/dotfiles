# Patterns are matched against TARGET paths (relative to $HOME), not source paths.
# Reference: https://www.chezmoi.io/reference/special-files-and-directories/chezmoiignore/

# Repository-only files (not deployed to home)
README.md
makefile
vichrome_keymappings.txt

# nvim auto-generated lockfile
.config/nvim/lazy-lock.json

# zed runtime data (LMDB binary)
.config/zed/prompts
.config/zed/prompts/**

# karabiner: only manage hand-authored complex_modifications presets.
# karabiner.json and automatic_backups/ are rewritten by the app constantly,
# and contain machine-specific device IDs, so we keep those local.
.config/karabiner/karabiner.json
.config/karabiner/automatic_backups
.config/karabiner/automatic_backups/**
.config/karabiner/system_default_profile.json

# Editor temp files
*.swp
*.swo
